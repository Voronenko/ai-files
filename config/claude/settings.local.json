{
  "permissions": {
    "allow": [
      "Bash(for:*)",
      "Bash(do grep -l \"## Communication Protocol\" \"$file\")",
      "Bash(done)",
      "Bash(python3:*)",
      "Bash(terraform validate:*)",
      "Bash(terraform fmt:*)"
      "Edit(./ai-files/sessions/**)",
      "Write(./ai-files/sessions/**)"
    ],
    "deny": [],
    "ask": []
  },
  "statusLine": {
    "type": "command",
    "command": "~/.ai-files/config/claude/statusline.sh",
    "padding": 0 // Optional: set to 0 to let status line go to edge
  }

}
