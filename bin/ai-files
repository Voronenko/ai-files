#!/usr/bin/env bash
set -euo pipefail

# Resolve the real path of the script, even if invoked via symlink
SCRIPT_PATH="$0"
while [ -h "$SCRIPT_PATH" ]; do
    DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
    SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
    [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$DIR/$SCRIPT_PATH"
done
SELF_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"

get_version() {
    local git_dir="${SELF_DIR}/../.git"
    if [ ! -d "$git_dir" ]; then
        echo "unknown"
        return
    fi

    # Check if we're on a tag
    local tag
    tag=$(git -C "${SELF_DIR}/.." describe --tags --exact-match 2>/dev/null || true)
    if [ -n "$tag" ]; then
        echo "$tag"
        return
    fi

    # If not on a tag, show branch name and commit hash
    local branch
    local commit_hash
    branch=$(git -C "${SELF_DIR}/.." rev-parse --abbrev-ref HEAD 2>/dev/null || echo "unknown")
    commit_hash=$(git -C "${SELF_DIR}/.." rev-parse --short=7 HEAD 2>/dev/null || echo "unknown")

    if [ "$branch" = "HEAD" ]; then
        # Detached HEAD state
        echo "detached-${commit_hash}"
    else
        echo "${branch}-${commit_hash}"
    fi
}

dispatch_to_external() {
    local cmd="$1"
    shift
    local external="${SELF_DIR}/ai-files-${cmd}"

    if [[ -x "$external" ]]; then
        exec "$external" "$@"
    fi
}

show_root_help() {
    cat <<EOF
Usage: ai-files <command> [options]

Commands:
  mcp          Configure and manage MCP servers
  update       Update ai-files utilities (if ai-files-update exists)
  version      Show version information

Any command can be overridden by placing a file:
  ai-files-<command>

EOF

    # Discover and list extension commands
    local extensions
    extensions=$(find "$SELF_DIR" -maxdepth 1 -type f -name "ai-files-*" -executable -printf "%f\n" 2>/dev/null | sed 's/^ai-files-//' | sort)

    if [ -n "$extensions" ]; then
        echo "Extension Commands:"
        echo "$extensions" | while read -r tool; do
            echo "  ai-files $tool"
        done
        echo ""
    fi

    cat <<EOF
Examples:
  ai-files mcp list
  ai-files update
  ai-files version
EOF
}

CMD="${1:-help}"
shift || true

# Try external override first
dispatch_to_external "$CMD" "$@"

case "$CMD" in
    help|-h|--help)
        show_root_help
        ;;
    skill)
        SUB="${1:-help}"
        shift || true
        case "$SUB" in
            enable)
                skill_enable="${SELF_DIR}/ai-files-skill-enable"
                if [[ -x "$skill_enable" ]]; then
                    exec "$skill_enable" "$@"
                else
                    echo "Error: ai-files-skill-enable not found." >&2
                    exit 1
                fi
                ;;
            disable)
                skill_disable="${SELF_DIR}/ai-files-skill-disable"
                if [[ -x "$skill_disable" ]]; then
                    exec "$skill_disable" "$@"
                else
                    echo "Error: ai-files-skill-disable not found." >&2
                    exit 1
                fi
                ;;
            help|-h|--help|"")
                cat <<EOF
Usage: ai-files skill <command> [options]

Manage Claude Code skills.

Commands:
  enable <name>      Enable a specific skill
  disable <name>     Disable a specific skill
  add <REPO> [OPTS]  Install skills from a git repository
  explore <REPO>     Explore a repo and generate gilt config

Examples:
  ai-files skill enable adr-tools
  ai-files skill disable lnav
  ai-files skill enable graphify --claude-only
  ai-files skill add vercel-labs/agent-skills --list
  ai-files skill explore obra/superpowers

See 'ai-files skill <command> --help' for more details.
EOF
                ;;
            *)
                _ext="${SELF_DIR}/ai-files-skills"
                if [[ -x "$_ext" ]]; then
                    exec "$_ext" "$SUB" "$@"
                fi
                echo "Error: Unknown skill command: $SUB" >&2
                echo "Valid commands: enable, disable, add, explore" >&2
                exit 1
                ;;
        esac
        ;;
    mcp)
        echo "Error: ai-files-mcp not found. Create executable: ${SELF_DIR}/ai-files-mcp" >&2
        exit 1
        ;;
    update)
        echo "No builtin update command. Provide ai-files-update." >&2
        exit 1
        ;;
    version)
        get_version
        ;;
    *)
        echo "Unknown command: $CMD" >&2
        show_root_help
        exit 1
        ;;
esac
