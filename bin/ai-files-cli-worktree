#!/bin/bash

# ai-files-cli-worktree - Set up ai-files symlinks in git worktrees
# This script sets up symlinks from the current git worktree to the main
# ai-files repository, enabling AI coding tools to work across worktrees.
#
# Usage: ai-files-cli worktree
#
# The script must be run from within a git worktree.

set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# expand_worktree_patterns - Expand glob patterns from .worktreeinclude
# Args:
#   $1 - Root directory to search
#   $2 - Path to .worktreeinclude file
# Output: List of matching file paths (relative to root)
expand_worktree_patterns() {
    local root_dir="$1"
    local include_file="$2"

    # Read patterns and expand them
    while IFS= read -r pattern || [[ -n "$pattern" ]]; do
        # Skip empty lines and comments
        [[ -z "$pattern" || "$pattern" =~ ^[[:space:]]*# ]] && continue

        # Expand glob pattern
        # Use find to handle ** patterns efficiently
        if [[ "$pattern" == *"**"* ]]; then
            # Recursive pattern - convert to find syntax
            local find_pattern="${pattern//\*\*/\*}"
            find "$root_dir" -name "$find_pattern" -type f 2>/dev/null | sed "s|^$root_dir/||" || true
        else
            # Simple glob - use shell expansion
            # Handle directory prefixes
            local dir_prefix=""
            if [[ "$pattern" == */* ]]; then
                dir_prefix="${pattern%/*}"
                local file_pattern="${pattern##*/}"
                if [[ -d "$root_dir/$dir_prefix" ]]; then
                    find "$root_dir/$dir_prefix" -maxdepth 1 -name "$file_pattern" -type f 2>/dev/null | sed "s|^$root_dir/||" || true
                fi
            else
                find "$root_dir" -maxdepth 1 -name "$pattern" -type f 2>/dev/null | sed "s|^$root_dir/||" || true
            fi
        fi
    done < "$include_file" | sort -u
}

# Functions for colored output
print_info() {
    echo -e "${BLUE}ℹ️  $1${NC}"
}

print_success() {
    echo -e "${GREEN}✅ $1${NC}"
}

print_warning() {
    echo -e "${YELLOW}⚠️  $1${NC}"
}

print_error() {
    echo -e "${RED}❌ $1${NC}"
}

show_help() {
    cat <<EOF
Usage: ai-files-cli worktree [-h|--help]

Set up ai-files symlinks in git worktrees.

Description:
  Creates symlinks from the current git worktree to the main ai-files repository,
  enabling AI coding tools to work across worktrees. Must be run from within a
  git worktree (not the main repository).

Requirements:
  - Must be run from within a git worktree
  - Main repository must contain .ai-files directory

Features:
  • Creates .ai-files symlink pointing to main repository
  • Copies symlinks for .claude, .kilo, .roo, .specify from main repo
  • Copies files matching .worktreeinclude patterns (if exists)
  • Interactive prompts for file conflicts

Examples:
  # Create a worktree and set up ai-files
  git worktree add ../my-feature -b feature/my-feature
  cd ../my-feature
  ai-files-cli worktree

Files:
  .worktreeinclude    Optional file with glob patterns of files to copy
                      from main repo to worktree (e.g., .env.local)

Exit codes:
  0  Success
  1  Error (not in worktree, missing .ai-files, etc.)
EOF
}

# Check if running in a git worktree
check_if_worktree() {
    if git rev-parse --git-dir 2>/dev/null | grep -q "/worktrees/"; then
        return 0
    else
        return 1
    fi
}

# Main setup function
setup_worktree() {
    # Check if we're in a git repository at all
    if ! git rev-parse --git-dir >/dev/null 2>&1; then
        print_error "Not in a git repository!"
        print_info "This command must be run from within a git worktree."
        echo ""
        echo "Usage:"
        echo "  1. Create a worktree: git worktree add <path> -b <branch>"
        echo "  2. cd <path>"
        echo "  3. ai-files-cli worktree"
        exit 1
    fi

    # Check if in worktree
    if ! check_if_worktree; then
        print_warning "Not running from within a git worktree."
        print_info "This command sets up ai-files symlinks in git worktrees."
        echo ""
        echo "You are currently in the main repository."
        exit 1
    fi

    local worktree_root
    worktree_root="$(git rev-parse --show-toplevel)"

    print_success "Running within git worktree: $worktree_root"

    # Find main git root
    print_info "Finding main ai-files repository..."
    local git_common_dir
    git_common_dir="$(git rev-parse --git-common-dir)"

    local main_repo_root
    main_repo_root="$(dirname "$git_common_dir")"

    if [[ ! -d "$main_repo_root/.ai-files" ]]; then
        print_error "Could not find .ai-files in main repository!"
        print_info "Main repository: $main_repo_root"
        exit 1
    fi

    print_success "Found main repository: $main_repo_root"

    # Create .ai-files symlink in worktree
    local ai_files_link="$worktree_root/.ai-files"
    if [[ -e "$ai_files_link" ]]; then
        if [[ -L "$ai_files_link" ]]; then
            print_warning ".ai-files symlink already exists"
            print_info "Removing old symlink..."
            rm "$ai_files_link"
        else
            print_error ".ai-files already exists and is not a symlink!"
            exit 1
        fi
    fi

    print_info "Creating .ai-files symlink..."
    ln -s "$main_repo_root/.ai-files" "$ai_files_link"
    print_success ".ai-files linked -> $main_repo_root/.ai-files"

    # Copy symlinks for .claude, .kilo, .roo, .specify
    local symlinks=(".claude" ".kilo" ".roo" ".specify")
    for symlink in "${symlinks[@]}"; do
        if [[ -L "$main_repo_root/$symlink" ]]; then
            if [[ -e "$worktree_root/$symlink" ]]; then
                print_warning "$symlink already exists, skipping"
            else
                local target
                target="$(readlink "$main_repo_root/$symlink")"
                ln -s "$target" "$worktree_root/$symlink"
                print_success "$symlink linked -> $target"
            fi
        fi
    done

    # Copy files from .worktreeinclude using glob patterns
    local worktree_include="$main_repo_root/.worktreeinclude"
    local override_all=false
    if [[ -f "$worktree_include" ]]; then
        print_info "Processing worktree files from .worktreeinclude..."

        # Expand glob patterns to get file list
        local files_to_copy
        files_to_copy=$(expand_worktree_patterns "$main_repo_root" "$worktree_include")

        if [[ -n "$files_to_copy" ]]; then
            while IFS= read -r file || [[ -n "$file" ]]; do
                [[ -z "$file" ]] && continue

                local src_file="$main_repo_root/$file"
                local dst_file="$worktree_root/$file"

                # Check if source file exists in main repository
                if [[ ! -e "$src_file" ]]; then
                    print_warning "Source file not found in main repository: $file (skipping)"
                    continue
                fi

                # Check if destination already exists
                if [[ -e "$dst_file" ]]; then
                    if [[ "$override_all" == true ]]; then
                        # Auto-override all
                        mkdir -p "$(dirname "$dst_file")"
                        cp "$src_file" "$dst_file"
                        print_success "Overridden: $file"
                    else
                        # Ask if user wants to override (read from terminal)
                        local response=""
                        echo -en "${YELLOW}Override existing file '$file' in worktree? [Y/n/A]: ${NC}"
                        read -r response < /dev/tty
                        case "$response" in
                            [Yy]*|"")
                                mkdir -p "$(dirname "$dst_file")"
                                cp "$src_file" "$dst_file"
                                print_success "Overridden: $file"
                                ;;
                            [Aa]*)
                                override_all=true
                                mkdir -p "$(dirname "$dst_file")"
                                cp "$src_file" "$dst_file"
                                print_success "Overridden: $file (will override all remaining)"
                                ;;
                            [Nn]*)
                                print_info "Skipped: $file"
                                ;;
                        esac
                    fi
                else
                    # Create destination directory if needed
                    mkdir -p "$(dirname "$dst_file")"
                    cp "$src_file" "$dst_file"
                    print_success "Copied: $file"
                fi
            done <<< "$files_to_copy"
        else
            print_warning "No files matched .worktreeinclude patterns"
        fi
    else
        print_info "No .worktreeinclude found in main repository (skipping worktree file copy)"
    fi

    # Show candidates for .worktreeinclude
    echo ""
    print_info "Candidates to add to .worktreeinclude:"
    if [[ -f "$worktree_include" ]]; then
        (cd "$main_repo_root" && git ls-files --others --ignored --exclude-standard \
            | grep -E '(\.env($|\.)|\.key$|\.pem$|\.local$)' \
            | grep -v '\.venv' \
            | grep -v -F -f .worktreeinclude 2>/dev/null || true)
    else
        (cd "$main_repo_root" && git ls-files --others --ignored --exclude-standard \
            | grep -E '(\.env($|\.)|\.key$|\.pem$|\.local$)' \
            | grep -v '\.venv' 2>/dev/null || true)
    fi

    echo ""
    print_success "Worktree setup complete!"
    echo ""
    echo "📋 Summary:"
    echo "   • .ai-files linked to $main_repo_root/.ai-files"
    echo "   • Agent symlinks copied from main repository"
    [[ -f "$worktree_include" ]] && echo "   • .worktreeinclude patterns applied"
    [[ -f "$main_repo_root/.mcp.json" ]] && echo "   • .mcp.json copied"
}

# Handle help flag
if [[ "${1:-}" == "-h" ]] || [[ "${1:-}" == "--help" ]]; then
    show_help
    exit 0
fi

# Run main function
setup_worktree
