#!/bin/sh

set -eu

readonly EX_USAGE=64
readonly EX_NOINPUT=66

get_git_repo_name() {
    git remote -v 2>/dev/null | head -1 | sed -E 's|.*[:/]([^/]+)\.git.*|\1|' || echo ""
}

is_session_file() {
    _isf_path=$(realpath "$1" 2>/dev/null || echo "")
    _isf_root=$(git rev-parse --show-toplevel 2>/dev/null || echo "")
    if [ -z "$_isf_path" ] || [ -z "$_isf_root" ]; then
        return 1
    fi
    _isf_sessions="$_isf_root/.ai-files/sessions"
    if [ -d "$1" ]; then
        [ "$_isf_path" = "$_isf_sessions" ] || [ "${_isf_path#"$_isf_sessions"/}" != "$_isf_path" ]
    else
        [ "${_isf_path#"$_isf_sessions"/}" != "$_isf_path" ]
    fi
}

obsidian_file_exists() {
    _vault="$1"
    _opath="$2"
    _result=$(obsidian file --vault "$_vault" --path "$_opath" </dev/null 2>&1 || true)
    _returned_path=$(echo "$_result" | head -1 | cut -f2)
    [ "$_returned_path" = "$_opath" ]
}

is_memory_file() {
    _imf_path=$(realpath "$1" 2>/dev/null || echo "")
    _imf_root=$(git rev-parse --show-toplevel 2>/dev/null || echo "")
    if [ -z "$_imf_path" ] || [ -z "$_imf_root" ]; then
        return 1
    fi
    _imf_base="$_imf_root/.ai-files"
    case "$_imf_path" in
        "$_imf_base/memory"|"$_imf_base"/memory/*) return 0 ;;
        *) return 1 ;;
    esac
}

# Check if /dev/tty is available for interactive prompts
is_tty_available() {
    [ -t 0 ] && [ -c /dev/tty ] 2>/dev/null
}

usage() {
    cat <<EOF
usage: $(basename "$0") [OPTIONS] <markdown-file|directory>

Add entries to Obsidian from markdown files with AI Files defaults.
Pass a directory to batch-add all .md files within it.
Flags can be placed anywhere in the command.

Resolution order for vault (-v):
  1. CLI flag -v
  2. Environment variable AI_FILES_VAULT
  3. Git config aifiles.vault

Resolution order for path (-p):
  1. CLI flag -p
  2. Environment variable AI_FILES_VAULT_DEFAULT_PATH
  3. Git config aifiles.vault-session-default-path (if file/dir is under .ai-files/sessions/)
  4. Git config aifiles.vault-memory-default-path (if file/dir is under .ai-files/memory*)
  5. Git config aifiles.vault-default-path
  6. Auto-discover from git repo name (pages/repo-<name>)

Auto-added tags:
  #session                  Added to session notes (under .ai-files/sessions/)
  #memory                   Added to memory notes (under .ai-files/memory*)
  #repo-<repo_name>         Current git repository name

Arguments:
  <markdown-file|directory>  File or directory of .md files to add

Options:
  -v, --vault <vault>        Target vault name
  -p, --path <path>          Folder path within vault
  -t, --tags <tags>          Additional comma-separated tags (e.g. "work,ideas")
  -n, --name <name>          Note name (defaults to source filename)
  -o, --open                 Open note after creating in Obsidian
  -y, --yes                  Auto-approve all prompts (non-interactive)
  -h, --help                 Show this help

Examples:
  $(basename "$0") ./note.md
  $(basename "$0") -v KB ./note.md
  $(basename "$0") -p "custom/path" ./note.md
  $(basename "$0") ./note.md -t "work,ideas" -o
  $(basename "$0") .ai-files/sessions/ -v KB --tags "logs"
  $(basename "$0") .ai-files/sessions/ -o -t "work"
  $(basename "$0") .ai-files/sessions/ --yes  # Non-interactive mode (CI/CD)
EOF
}

vault=""
folder_path=""
tags=""
note_name=""
open_flag=""
yes_mode=""
input_path=""

# Parse all arguments, allowing flags anywhere
_i=1
while [ $_i -le $# ]; do
    eval "_arg=\${$_i}"
    _i=$((_i + 1))

    case "$_arg" in
        -h|--help)
            usage
            exit 0
            ;;
        -v=*|--vault=*)
            vault="${_arg#*=}"
            ;;
        -p=*|--path=*)
            folder_path="${_arg#*=}"
            ;;
        -t=*|--tags=*)
            tags="${_arg#*=}"
            ;;
        -n=*|--name=*)
            note_name="${_arg#*=}"
            ;;
        --open|-o)
            open_flag="open"
            ;;
        --yes|-y)
            yes_mode="yes"
            ;;
        -v|--vault)
            eval "vault=\${$_i}"
            _i=$((_i + 1))
            ;;
        -p|--path)
            eval "folder_path=\${$_i}"
            _i=$((_i + 1))
            ;;
        -t|--tags)
            eval "tags=\${$_i}"
            _i=$((_i + 1))
            ;;
        -n|--name)
            eval "note_name=\${$_i}"
            _i=$((_i + 1))
            ;;
        -*)
            echo "$(basename "$0"): unknown option: $_arg" >&2
            usage
            exit $EX_USAGE
            ;;
        *)
            # Positional argument (input path)
            if [ -z "$input_path" ]; then
                input_path="$_arg"
            else
                echo "$(basename "$0"): too many arguments" >&2
                usage
                exit $EX_USAGE
            fi
            ;;
    esac
done

if [ -z "$input_path" ]; then
    usage
    exit $EX_USAGE
fi

if [ ! -e "$input_path" ]; then
    echo "$(basename "$0"): $input_path: No such file or directory" >&2
    exit $EX_NOINPUT
fi

# Resolve vault: CLI flag → env var → git config
if [ -z "$vault" ]; then
    vault="${AI_FILES_VAULT:-}"
fi
if [ -z "$vault" ]; then
    vault=$(git config aifiles.vault 2>/dev/null || true)
fi
if [ -z "$vault" ]; then
    echo "error: vault is required (set via -v flag, \$AI_FILES_VAULT, or git config aifiles.vault)" >&2
    usage
    exit $EX_USAGE
fi

# Resolve folder path: CLI flag → env var → git config (session/default) → auto-discover
if [ -z "$folder_path" ]; then
    folder_path="${AI_FILES_VAULT_DEFAULT_PATH:-}"
fi
if [ -z "$folder_path" ]; then
    if is_session_file "$input_path"; then
        folder_path=$(git config aifiles.vault-session-default-path 2>/dev/null || true)
    fi
fi
if [ -z "$folder_path" ]; then
    if is_memory_file "$input_path"; then
        folder_path=$(git config aifiles.vault-memory-default-path 2>/dev/null || true)
        if [ -z "$folder_path" ]; then
            folder_path=$(git config aifiles.vault-default-path 2>/dev/null || true)
            if [ -n "$folder_path" ]; then
                folder_path="$folder_path/memory"
            fi
        fi
    fi
fi
if [ -z "$folder_path" ]; then
    folder_path=$(git config aifiles.vault-default-path 2>/dev/null || true)
fi
if [ -z "$folder_path" ]; then
    _repo_name=$(get_git_repo_name)
    if [ -n "$_repo_name" ]; then
        folder_path="pages/repo-$_repo_name"
    fi
fi

# Build auto tags
if is_memory_file "$input_path"; then
    auto_tags="memory"
else
    auto_tags="session"
fi
_repo_name=$(get_git_repo_name)
if [ -n "$_repo_name" ]; then
    auto_tags="$auto_tags,repo-$_repo_name"
fi

# Combine with user-provided tags
if [ -n "$tags" ]; then
    tags="$auto_tags,$tags"
else
    tags="$auto_tags"
fi

build_base_cmd() {
    _cmd="obsidian-add -v \"$vault\" -t \"$tags\""
    if [ -n "$folder_path" ]; then
        _cmd="$_cmd -p \"$folder_path\""
    fi
    if [ -n "$note_name" ]; then
        _cmd="$_cmd -n \"$note_name\""
    fi
    if [ -n "$open_flag" ]; then
        _cmd="$_cmd -o"
    fi
    echo "$_cmd"
}

add_single_file() {
    _file="$1"
    _force="$2"
    _base_cmd=$(build_base_cmd)

    if [ -n "$note_name" ]; then
        _dest_name="$note_name"
    else
        _dest_name=$(basename "$_file" .md)
    fi

    if [ -n "$folder_path" ]; then
        _dest_path="$folder_path/$_dest_name.md"
    else
        _dest_path="$_dest_name.md"
    fi

    if obsidian_file_exists "$vault" "$_dest_path"; then
        echo "  EXISTS: $_dest_path"
        if [ "$_force" = "yes" ]; then
            echo "  Overwriting (All mode)..."
        elif [ "$yes_mode" = "yes" ] || ! is_tty_available; then
            echo "  Auto-approving overwrite (non-interactive mode)"
        else
            printf "  Overwrite in Obsidian? [y/N]: "
            _ow_response=""
            read -r _ow_response </dev/tty || true
            case "$_ow_response" in
                [Yy]*) ;;
                *) echo "  Skipping $_file"; return 0 ;;
            esac
        fi
    fi

    eval "$_base_cmd \"$_file\""
    echo "  Added: $_file → $_dest_path"
}

# ── Single file mode ──
if [ -f "$input_path" ]; then
    add_single_file "$input_path" "no"
    exit 0
fi

# ── Directory mode ──
if [ -d "$input_path" ]; then
    _md_list_file=""
    _count=0
    for _f in "$input_path"/*.md; do
        if [ -f "$_f" ]; then
            if [ -z "$_md_list_file" ]; then
                _md_list_file=$(mktemp)
            fi
            echo "$_f" >> "$_md_list_file"
            _count=$((_count + 1))
        fi
    done

    if [ "$_count" -eq 0 ]; then
        echo "$(basename "$0"): no .md files found in $input_path" >&2
        [ -n "$_md_list_file" ] && rm -f "$_md_list_file"
        exit $EX_NOINPUT
    fi

    echo "Directory detected: $input_path"
    echo "Found $_count markdown file(s):"
    while IFS= read -r _f <&3; do
        printf "  - %s\n" "$(basename "$_f")"
    done 3< "$_md_list_file"
    echo ""

    if [ "$yes_mode" = "yes" ] || ! is_tty_available; then
        _dir_response="A"
    else
        printf "Add all files? [Y/n/A]: "
        _dir_response=""
        read -r _dir_response </dev/tty || true
        _dir_response="${_dir_response:-Y}"
    fi

    case "$_dir_response" in
        [Aa])
            echo ""
            echo "Adding all files..."
            while IFS= read -r _f <&3; do
                add_single_file "$_f" "yes"
            done 3< "$_md_list_file"
            ;;
        [Yy]|[Yy][Ee][Ss]|"")
            echo ""
            echo "Adding files with confirmation..."
            while IFS= read -r _f <&3; do
                _fname=$(basename "$_f")
                printf "Add %s? [Y/n]: " "$_fname"
                _f_response=""
                read -r _f_response </dev/tty || true
                _f_response="${_f_response:-Y}"
                case "$_f_response" in
                    [Nn]|[Nn][Oo]) echo "  Skipping $_fname" ;;
                    *) add_single_file "$_f" "no" ;;
                esac
            done 3< "$_md_list_file"
            ;;
        *)
            echo "Cancelled."
            rm -f "$_md_list_file"
            exit 0
            ;;
    esac
    rm -f "$_md_list_file"
    exit 0
fi

echo "$(basename "$0"): $input_path: Not a file or directory" >&2
exit $EX_NOINPUT
