#!/usr/bin/env bash
#
# ai-files-skill-enable - Enable a Claude Code skill by creating symlinks
#
# This script creates symlinks from .claude/skills/ and/or .kilo/skills/
# to skills in .ai-files/skills/ or .ai-files/dotclaude/skills/
#
# Usage: ai-files-skill-enable <skill-name> [OPTIONS]

set -euo pipefail

readonly EXIT_SUCCESS=0
readonly EXIT_INVALID_SKILL=1
readonly EXIT_PERMISSION=2
readonly EXIT_ERROR=3

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Resolve script location
SCRIPT_PATH="$0"
while [ -h "$SCRIPT_PATH" ]; do
    DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
    SCRIPT_PATH="$(readlink "$SCRIPT_PATH")"
    [[ "$SCRIPT_PATH" != /* ]] && SCRIPT_PATH="$DIR/$SCRIPT_PATH"
done
SELF_DIR="$(cd -P "$(dirname "$SCRIPT_PATH")" && pwd)"
PROJECT_ROOT="$(cd "$SELF_DIR/.." && pwd)"

# Command-line options
CLAUDE_ONLY=false
KILO_ONLY=false
SKILL_NAME=""

error() {
    echo -e "${RED}Error:${NC} $1" >&2
}

success() {
    echo -e "${GREEN}✓${NC} $1"
}

info() {
    echo "  $1"
}

show_help() {
    cat <<EOF
Usage: ai-files skill enable <skill-name> [OPTIONS]

Enable a Claude Code skill by creating symlinks in target directories.

Arguments:
  skill-name              Name of the skill to enable (required)

Options:
  --claude-only           Enable only for Claude (.claude/skills/)
  --kilo-only            Enable only for Kilo (.kilo/skills/)
  -h, --help             Show this help message

Examples:
  ai-files skill enable adr-tools
  ai-files skill enable lnav --claude-only
  ai-files skill enable graphify --kilo-only

Skills are sourced from:
  - .ai-files/skills/
  - .ai-files/dotclaude/skills/
EOF
}

find_skill_source() {
    local skill="$1"
    local skill_path=""

    # Check .ai-files/skills/ first
    if [ -d "$PROJECT_ROOT/.ai-files/skills/$skill" ]; then
        skill_path="$PROJECT_ROOT/.ai-files/skills/$skill"
    # Check .ai-files/dotclaude/skills/
    elif [ -d "$PROJECT_ROOT/.ai-files/dotclaude/skills/$skill" ]; then
        skill_path="$PROJECT_ROOT/.ai-files/dotclaude/skills/$skill"
    fi

    echo "$skill_path"
}

get_symlink_target() {
    local source_path="$1"
    local target_dir="$2"
    local skill_name="$3"

    # Manual relative path calculation based on known directory structure
    local relative_path="../../.ai-files/skills/$skill_name"

    # Check if source is in dotclaude directory
    if [[ "$source_path" == *"dotclaude"* ]]; then
        relative_path="../../.ai-files/dotclaude/skills/$skill_name"
    fi

    echo "$relative_path"
}

enable_skill_in_dir() {
    local skill_name="$1"
    local source_path="$2"
    local target_dir="$3"
    local target_path="$target_dir/$skill_name"

    # Create target directory if it doesn't exist
    if [ ! -d "$target_dir" ]; then
        mkdir -p "$target_dir" 2>/dev/null || {
            error "Cannot create target directory: $target_dir"
            return "$EXIT_PERMISSION"
        }
    fi

    # Check if already enabled
    if [ -L "$target_path" ]; then
        if [ -e "$target_path" ]; then
            info "Already enabled: ${target_path#"$PROJECT_ROOT/"}"
            return 0
        else
            # Broken symlink, remove it
            rm -f "$target_path" 2>/dev/null || true
        fi
    fi

    # Get relative symlink target
    local relative_target
    relative_target=$(get_symlink_target "$source_path" "$target_dir" "$skill_name")

    # Create symlink
    ln -s "$relative_target" "$target_path" 2>/dev/null || {
        error "Failed to create symlink in $(basename "$target_dir")"
        return "$EXIT_ERROR"
    }

    local rel_path="${target_path#"$PROJECT_ROOT/"}"
    success "Created $rel_path"
    return 0
}

parse_arguments() {
    while [[ $# -gt 0 ]]; do
        case $1 in
            --claude-only)
                CLAUDE_ONLY=true
                ;;
            --kilo-only)
                KILO_ONLY=true
                ;;
            -h|--help)
                show_help
                exit "$EXIT_SUCCESS"
                ;;
            -*)
                error "Unknown option: $1"
                show_help
                exit "$EXIT_ERROR"
                ;;
            *)
                if [ -z "$SKILL_NAME" ]; then
                    SKILL_NAME="$1"
                else
                    error "Unexpected argument: $1"
                    show_help
                    exit "$EXIT_ERROR"
                fi
                ;;
        esac
        shift
    done

    if [ -z "$SKILL_NAME" ]; then
        error "Skill name is required"
        show_help
        exit "$EXIT_ERROR"
    fi

    if [[ "$CLAUDE_ONLY" == true ]] && [[ "$KILO_ONLY" == true ]]; then
        error "Options --claude-only and --kilo-only are mutually exclusive"
        exit "$EXIT_ERROR"
    fi
}

main() {
    parse_arguments "$@"

    # Find skill source
    local skill_source
    skill_source=$(find_skill_source "$SKILL_NAME")

    if [ -z "$skill_source" ]; then
        error "Skill not found: $SKILL_NAME"
        echo "" >&2
        echo "Available skills:" >&2
        find "$PROJECT_ROOT/.ai-files/skills" -mindepth 1 -maxdepth 1 -type d -not -name ".*" -exec basename {} \; 2>/dev/null | while read -r skill; do
            echo "  - $skill" >&2
        done
        find "$PROJECT_ROOT/.ai-files/dotclaude/skills" -mindepth 1 -maxdepth 1 -type d -not -name ".*" -exec basename {} \; 2>/dev/null | while read -r skill; do
            echo "  - $skill" >&2
        done
        exit "$EXIT_INVALID_SKILL"
    fi

    echo "Enabling skill: $SKILL_NAME"

    # Enable in Claude
    if [[ "$KILO_ONLY" != true ]]; then
        enable_skill_in_dir "$SKILL_NAME" "$skill_source" "$PROJECT_ROOT/.claude/skills"
    fi

    # Enable in Kilo
    if [[ "$CLAUDE_ONLY" != true ]]; then
        enable_skill_in_dir "$SKILL_NAME" "$skill_source" "$PROJECT_ROOT/.kilo/skills"
    fi

    echo ""
    success "Skill enabled successfully"
}

main "$@"
